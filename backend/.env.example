# 📈 cTrader API
CTRADER_CLIENT_ID=your_ctrader_client_id
CTRADER_CLIENT_SECRET=your_ctrader_client_secret
CTRADER_HOST_TYPE=demo  # or 'live'
CTRADER_ACCESS_TOKEN=your_ctrader_access_token
CTRADER_ACCOUNT_ID=your_ctrader_account_id

# ===== LLM =====
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi3:mini

# ===== Optional defaults =====
DEFAULT_SYMBOL=XAUUSD

# ===== Security (optional) =====
# Protects API routes; dashboard must send the same key via x-api-key when set
API_KEY=change-me
# Comma-separated origins for CORS (defaults to http://localhost:8080)
ALLOWED_ORIGINS=http://localhost:8080
# Enable external news fetching + summarization (defaults off for safety)
NEWS_SUMMARY_ENABLED=0
# Looser SL/TP amend tolerance (price units); helpful for indices/metals with coarse digits
# SMC_AMEND_TOL=0.1
# Override symbols for the auto checklist (set to your broker's tickers)
# CHECKLIST_SYMBOL_DXY=USDX
# Optional: static next red event (unix seconds) to drive checklist lockouts
# CALENDAR_NEXT_TS=
# CALENDAR_NEXT_TITLE=
# CALENDAR_NEXT_IMPACT=high
